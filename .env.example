# 百度 OCR（试卷切题）— 使用 API Key / Secret Key 换取 access_token
BAIDU_OCR_AK=your_ocr_api_key
BAIDU_OCR_SK=your_ocr_secret_key

# 千帆多模态 — 控制台「安全认证 → API Key」创建的完整 Key（与 OCR AK/SK 不同）
# 格式示例：bce-v3/ALTAK-xxxxxxxx/xxxxxxxx
QIANFAN_API_KEY=bce-v3/ALTAK-your_key/your_secret

# 华严 OpenAI 兼容网关 — 豆包等模型（sk- 开头）
HUAYAN_API_KEY=sk-your_huayan_key
# HUAYAN_API_BASE=https://www.huayanapi.com/v1

# 日志级别：DEBUG / INFO / WARNING（默认 INFO）
# LOG_LEVEL=DEBUG
